// Product Mockup Canvas — Prisma schema (PostgreSQL)
// Data structure theo product_mockup_canvas_mvp_structure.md §7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(uuid())
  sku       String   @unique
  name      String
  category  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  images   ProductImage[]
  projects MockupProject[]

  @@map("products")
}

model ProductImage {
  id             String   @id @default(uuid())
  productId      String   @map("product_id")
  originalUrl    String   @map("original_url")
  transparentUrl String?  @map("transparent_url")
  fileName       String   @map("file_name")
  width          Int
  height         Int
  createdAt      DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// Layer system preset: Background -> Template -> Shadow -> Product -> Overlay
model MockupTemplate {
  id         String   @id @default(uuid())
  name       String
  type       String // white-studio | minimal-interior | pastel-sunlight | custom
  previewUrl String?  @map("preview_url")
  canvasJson Json     @map("canvas_json")
  createdAt  DateTime @default(now()) @map("created_at")

  projects MockupProject[]

  @@map("mockup_templates")
}

// Thư viện background: ảnh nền upload sẵn, chọn lại bất cứ lúc nào.
model Background {
  id           String   @id @default(uuid())
  name         String
  imageUrl     String   @map("image_url")
  thumbnailUrl String?  @map("thumbnail_url")
  fileName     String   @map("file_name")
  width        Int
  height       Int
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("backgrounds")
}

model MockupProject {
  id         String   @id @default(uuid())
  name       String   @default("Untitled mockup")
  productId  String?  @map("product_id")
  templateId String?  @map("template_id")
  canvasJson Json     @map("canvas_json")
  exportUrl  String?  @map("export_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  product  Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  template MockupTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([templateId])
  @@map("mockup_projects")
}
